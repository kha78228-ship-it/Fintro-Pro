{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction (income or expense)",
      "type": "object",
      "properties": {
        "amount": { "type": "number", "description": "Transaction amount" },
        "type": { "type": "string", "enum": ["income", "expense"], "description": "Type of transaction" },
        "category": { "type": "string", "description": "Category ID or name" },
        "description": { "type": "string", "description": "Note or description" },
        "date": { "type": "string", "format": "date-time", "description": "Transaction date" },
        "userId": { "type": "string", "description": "Owner ID" }
      },
      "required": ["amount", "type", "category", "date", "userId"]
    },
    "Budget": {
      "title": "Budget",
      "description": "Spending limit for a category",
      "type": "object",
      "properties": {
        "categoryId": { "type": "string", "description": "Category ID" },
        "amount": { "type": "number", "description": "Budget limit" },
        "period": { "type": "string", "enum": ["monthly"], "description": "Budget period" },
        "userId": { "type": "string", "description": "Owner ID" }
      },
      "required": ["categoryId", "amount", "period", "userId"]
    },
    "Category": {
      "title": "Category",
      "description": "Transaction category",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Category name" },
        "icon": { "type": "string", "description": "Lucide icon name" },
        "type": { "type": "string", "enum": ["income", "expense", "both"], "description": "Associated transaction type" },
        "userId": { "type": "string", "description": "Owner ID (null for system categories)" }
      },
      "required": ["name", "icon", "type"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User preferences and profile",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "currency": { "type": "string", "description": "Preferred currency code" }
      },
      "required": ["displayName", "email"]
    },
    "Goal": {
      "title": "Goal",
      "description": "Savings goal",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "targetAmount": { "type": "number" },
        "currentAmount": { "type": "number" },
        "deadline": { "type": "string", "format": "date" },
        "icon": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["name", "targetAmount", "currentAmount", "userId"]
    },
    "SharedFund": {
      "title": "Shared Fund",
      "description": "Shared family finances",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "memberIds": { "type": "array", "items": { "type": "string" } },
        "members": { "type": "object" },
        "funds": { "type": "array" },
        "contributionMode": { "type": "string", "enum": ["income", "equal", "custom"], "description": "Contribution split calculation method" },
        "targetBudget": { "type": "number", "description": "Monthly general target budget goal" }
      },
      "required": ["ownerId", "memberIds", "members", "funds"]
    },
    "CoupleData": {
      "title": "Couple Data",
      "description": "Shared data between couples (games, daily questions)",
      "type": "object",
      "properties": {
        "question": { "type": "string" },
        "answers": { "type": "object" },
        "scores": { "type": "object" },
        "questions": { "type": "array" },
        "authorId": { "type": "string" }
      }
    },
    "Photo": {
      "title": "Photo",
      "description": "Shared photo album",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "description": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "object" }
      },
      "required": ["url", "createdBy", "createdAt", "description"]
    },
    "SystemAnnouncement": {
      "title": "System Announcement",
      "description": "Global system announcement settings",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "isMarquee": { "type": "boolean" },
        "textColor": { "type": "string" },
        "backgroundColor": { "type": "string" },
        "fontFamily": { "type": "string" },
        "fontSize": { "type": "number" },
        "show": { "type": "boolean" },
        "updatedAt": { "type": "object" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "time": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["type", "title", "description", "time", "read", "createdAt"]
    },
    "Diary": {
      "title": "Diary",
      "description": "Diary entry for capturing sweet moments and thoughts",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the entry" },
        "content": { "type": "string", "description": "Markdown content" },
        "date": { "type": "string", "description": "Date of the entry" },
        "photos": { "type": "array", "items": { "type": "string" }, "description": "Array of base64 or Unsplash URLs" },
        "createdAt": { "type": "object", "description": "Server timestamp of creation" }
      },
      "required": ["title", "content", "date", "photos", "createdAt"]
    }
  },
  "firestore": {
    "/system/{systemDocId}": {
       "schema": "SystemAnnouncement",
       "description": "System-wide configs and announcements"
    },
    "/users/{userId}/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "/couple_data/{dataId}": {
       "schema": "CoupleData",
       "description": "Couple specific shared data like games or questions"
    },
    "/couple_data/{dataId}/diaries/{diaryId}": {
       "schema": "Diary",
       "description": "Couple diary memories"
    },
    "/shared_funds/{fundId}": {
      "schema": "SharedFund",
      "description": "Shared family fund"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/users/{userId}/diaries/{diaryId}": {
      "schema": "Diary",
      "description": "User personal diary memories"
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "User transactions"
    },
    "/users/{userId}/budgets/{budgetId}": {
      "schema": "Budget",
      "description": "User budgets"
    },
    "/users/{userId}/goals/{goalId}": {
      "schema": "Goal",
      "description": "User savings goals"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "System or global categories"
    },
    "/photos/{photoId}": {
      "schema": "Photo",
      "description": "Shared photo album photos"
    }
  }
}
