{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction (income or expense)",
      "type": "object",
      "properties": {
        "amount": { "type": "number", "description": "Transaction amount" },
        "type": { "type": "string", "enum": ["income", "expense"], "description": "Type of transaction" },
        "category": { "type": "string", "description": "Category ID or name" },
        "description": { "type": "string", "description": "Note or description" },
        "date": { "type": "string", "format": "date-time", "description": "Transaction date" },
        "userId": { "type": "string", "description": "Owner ID" }
      },
      "required": ["amount", "type", "category", "date", "userId"]
    },
    "Budget": {
      "title": "Budget",
      "description": "Spending limit for a category",
      "type": "object",
      "properties": {
        "categoryId": { "type": "string", "description": "Category ID" },
        "amount": { "type": "number", "description": "Budget limit" },
        "period": { "type": "string", "enum": ["monthly"], "description": "Budget period" },
        "userId": { "type": "string", "description": "Owner ID" }
      },
      "required": ["categoryId", "amount", "period", "userId"]
    },
    "Category": {
      "title": "Category",
      "description": "Transaction category",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Category name" },
        "icon": { "type": "string", "description": "Lucide icon name" },
        "type": { "type": "string", "enum": ["income", "expense", "both"], "description": "Associated transaction type" },
        "userId": { "type": "string", "description": "Owner ID (null for system categories)" }
      },
      "required": ["name", "icon", "type"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User preferences and profile",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "currency": { "type": "string", "description": "Preferred currency code" }
      },
      "required": ["displayName", "email"]
    },
    "Goal": {
      "title": "Goal",
      "description": "Savings goal",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "targetAmount": { "type": "number" },
        "currentAmount": { "type": "number" },
        "deadline": { "type": "string", "format": "date" },
        "icon": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["name", "targetAmount", "currentAmount", "userId"]
    },
    "SharedFund": {
      "title": "Shared Fund",
      "description": "Shared family finances",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "memberIds": { "type": "array", "items": { "type": "string" } },
        "members": { "type": "object" },
        "funds": { "type": "array" }
      },
      "required": ["ownerId", "memberIds", "members", "funds"]
    }
  },
  "firestore": {
    "/shared_funds/{fundId}": {
      "schema": "SharedFund",
      "description": "Shared family fund"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "User transactions"
    },
    "/users/{userId}/budgets/{budgetId}": {
      "schema": "Budget",
      "description": "User budgets"
    },
    "/users/{userId}/goals/{goalId}": {
      "schema": "Goal",
      "description": "User savings goals"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "System or global categories"
    }
  }
}
