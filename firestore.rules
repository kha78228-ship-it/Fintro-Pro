rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    
    function isValidTransaction(data) {
      return data.keys().hasAll(['amount', 'type', 'category', 'description', 'date', 'userId'])
        && data.keys().size() == 6
        && data.amount is number && data.amount >= 0
        && data.type in ['income', 'expense']
        && data.category is string && data.category.size() <= 100
        && data.description is string && data.description.size() <= 1000
        && data.date is string && data.date.size() <= 32
        && data.userId == request.auth.uid;
    }

    function isValidBudget(data) {
      return data.keys().hasAll(['categoryId', 'amount', 'period', 'userId'])
        && data.keys().size() == 4
        && data.categoryId is string && data.categoryId.size() <= 128
        && data.amount is number && data.amount >= 0
        && data.period == 'monthly'
        && data.userId == request.auth.uid;
    }

    function isValidProfile(data) {
      return data.keys().hasAll(['displayName', 'email', 'currency'])
        && data.keys().size() == 3
        && data.displayName is string && data.displayName.size() <= 100
        && data.email == request.auth.token.email
        && data.currency is string && data.currency.size() <= 10;
    }

    // --- Rules ---

    // User Profile
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidProfile(incoming());
      allow update: if isOwner(userId) && isValidProfile(incoming())
        && incoming().email == existing().email; // Email immutable
    }

    // User Transactions
    match /users/{userId}/transactions/{transactionId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(transactionId) && isValidTransaction(incoming());
      allow update: if isOwner(userId) && isValidTransaction(incoming())
        && incoming().userId == existing().userId; // Owner ID immutable
      allow delete: if isOwner(userId);
    }

    // User Budgets
    match /users/{userId}/budgets/{budgetId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(budgetId) && isValidBudget(incoming());
      allow update: if isOwner(userId) && isValidBudget(incoming())
        && incoming().userId == existing().userId;
      allow delete: if isOwner(userId);
    }

    function isValidGoal(data) {
      return data.keys().hasAll(['name', 'targetAmount', 'currentAmount', 'icon', 'userId'])
        && data.keys().size() >= 5
        && data.name is string && data.name.size() <= 100
        && data.targetAmount is number && data.targetAmount > 0
        && data.currentAmount is number && data.currentAmount >= 0
        && data.icon is string
        && data.userId == request.auth.uid;
    }

    // User Goals
    match /users/{userId}/goals/{goalId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(goalId) && isValidGoal(incoming());
      allow update: if isOwner(userId) && isValidGoal(incoming())
        && incoming().userId == existing().userId;
      allow delete: if isOwner(userId);
    }

    // Global Categories
    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if false; // System generated
    }

    function isValidSharedFund(data) {
      return data.keys().hasAll(['ownerId', 'memberIds', 'members', 'funds'])
        && data.keys().size() >= 4
        && data.ownerId is string
        && data.memberIds is list && data.memberIds.size() > 0 && data.memberIds.size() <= 10
        && data.members is map
        && data.funds is list;
    }

    // Shared Funds
    match /shared_funds/{fundId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && request.auth.uid in resource.data.memberIds;
      allow create: if isSignedIn() && isValidId(fundId) && isValidSharedFund(incoming())
        && incoming().ownerId == request.auth.uid
        && request.auth.uid in incoming().memberIds;
      allow update: if isSignedIn() && isValidSharedFund(incoming())
        && incoming().ownerId == existing().ownerId
        && (request.auth.uid in existing().memberIds || 
            (request.auth.uid in incoming().memberIds && incoming().memberIds.hasAll(existing().memberIds)));
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;
    }
  }
}
