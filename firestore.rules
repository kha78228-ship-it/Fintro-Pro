rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.email == 'kha78228@gmail.com';
    }

    function isAdmin() {
      return isSuperAdmin() || (
        request.auth != null && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.expiresAt > request.time
      );
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    
    function isValidTransaction(data) {
      return data.keys().hasAll(['amount', 'type', 'status', 'category', 'description', 'date', 'userId'])
        && data.keys().size() == 7
        && data.amount is number && data.amount >= 0
        && data.type in ['income', 'expense']
        && data.status in ['completed', 'pending', 'cancelled']
        && data.category is string && data.category.size() <= 100
        && data.description is string && data.description.size() <= 1000
        && data.date is string && data.date.size() <= 32
        && data.userId == request.auth.uid;
    }

    function isValidBudget(data) {
      return data.keys().hasAll(['categoryId', 'amount', 'period', 'userId'])
        && data.keys().size() == 4
        && data.categoryId is string && data.categoryId.size() <= 128
        && data.amount is number && data.amount >= 0
        && data.period == 'monthly'
        && data.userId == request.auth.uid;
    }

    function isFullValidProfile(data) {
      return data.keys().hasAll(['displayName', 'currency'])
        && data.keys().size() >= 2
        && data.displayName is string && data.displayName.size() <= 100
        && (!('email' in data) || data.email is string)
        && data.currency is string && data.currency.size() <= 10
        && (!('friendCode' in data) || (data.friendCode is string && data.friendCode.matches('^[0-9]{3,12}$')));
    }

    function isPartialValidProfile(data) {
      return (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100))
        && (!('email' in data) || data.email is string)
        && (!('currency' in data) || (data.currency is string && data.currency.size() <= 10))
        && (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1000))
        && (!('nickname' in data) || (data.nickname is string && data.nickname.size() <= 100))
        && (!('status' in data) || data.status is string)
        && (!('lastSeen' in data) || data.lastSeen != null)
        && (!('gender' in data) || data.gender is string)
        && (!('isCycleVisibleToPartner' in data) || data.isCycleVisibleToPartner is bool)
        && (!('friendCode' in data) || (data.friendCode is string && data.friendCode.matches('^[0-9]{3,12}$')));
    }

    // --- Rules ---

    // User Profile
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isFullValidProfile(incoming());
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /publicProfiles/{userId} {
      allow read: if isSignedIn();
      // Admin bypasses validation for write
      allow write: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // User Transactions
    match /users/{userId}/transactions/{transactionId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(transactionId) && isValidTransaction(incoming());
      allow update: if isOwner(userId) && isValidTransaction(incoming())
        && incoming().userId == existing().userId; // Owner ID immutable
      allow delete: if isOwner(userId);
    }

    // User Budgets
    match /users/{userId}/budgets/{budgetId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(budgetId) && isValidBudget(incoming());
      allow update: if isOwner(userId) && isValidBudget(incoming())
        && incoming().userId == existing().userId;
      allow delete: if isOwner(userId);
    }

    function isValidGoal(data) {
      return data.keys().hasAll(['name', 'targetAmount', 'currentAmount', 'icon', 'userId'])
        && data.keys().size() >= 5
        && data.name is string && data.name.size() <= 100
        && data.targetAmount is number && data.targetAmount > 0
        && data.currentAmount is number && data.currentAmount >= 0
        && data.icon is string
        && data.userId == request.auth.uid;
    }

    // User Goals
    match /users/{userId}/goals/{goalId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(goalId) && isValidGoal(incoming());
      allow update: if isOwner(userId) && isValidGoal(incoming())
        && incoming().userId == existing().userId;
      allow delete: if isOwner(userId);
    }
    
    function isValidForgetMeNot(data) {
      return data.keys().hasAll(['title', 'value', 'iconType'])
        && data.title is string && data.title.size() > 0 && data.title.size() <= 100
        && data.value is string && data.value.size() > 0 && data.value.size() <= 1000
        && data.iconType is string && data.iconType.size() > 0 && data.iconType.size() <= 50;
    }

    match /users/{userId}/forgetMeNots/{noteId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(noteId) && isValidForgetMeNot(incoming());
      allow update: if isOwner(userId) && isValidForgetMeNot(incoming());
      allow delete: if isOwner(userId);
    }

    function isValidFriend(data) {
      return data.keys().hasAll(['friendId', 'status', 'createdAt'])
        && data.friendId is string
        && data.status in ['pending', 'accepted']
        && data.createdAt != null
        && (!('relationshipType' in data) || data.relationshipType is string)
        && (!('relationshipStartDate' in data) || data.relationshipStartDate is string);
    }

    function isValidFriendRequest(data) {
      return data.keys().hasAll(['senderId', 'receiverId', 'status', 'createdAt'])
        && data.senderId == request.auth.uid
        && data.status in ['pending', 'accepted', 'rejected']
        && data.createdAt != null;
    }

    match /friendRequests/{requestId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (request.auth.uid == resource.data.receiverId || request.auth.uid == resource.data.senderId);
      allow create: if isSignedIn() && isValidId(requestId) && isValidFriendRequest(incoming());
      allow update: if isSignedIn() && (request.auth.uid == resource.data.receiverId || request.auth.uid == resource.data.senderId)
        && incoming().status in ['pending', 'accepted', 'rejected'];
    }

    match /users/{userId}/friends/{friendId} {
      allow list, get: if isOwner(userId);
      allow create: if (isOwner(userId) || isOwner(friendId)) && isValidId(friendId) && isValidFriend(incoming());
      allow update: if (isOwner(userId) || isOwner(friendId)) && isValidFriend(incoming());
      allow delete: if (isOwner(userId) || isOwner(friendId));
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'text', 'timestamp'])
        && data.senderId == request.auth.uid
        && data.text is string && data.text.size() > 0 && data.text.size() <= 2000;
    }

    match /chats/{chatId} {
      allow list: if isSignedIn(); // We could restrict more if needed, but we check friendId
      allow get: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(messageId) && isValidMessage(incoming());
    }

    match /calls/{callId} {
      allow read, write: if isSignedIn();
    }
    
    match /calls/{callId}/{colName}/{docId} {
      allow read, write: if isSignedIn();
    }

    // Global Categories
    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if false; // System generated
    }

    match /admins/{adminId} {
      // Only the super admin can write admins, but users can read their own
      allow read: if isSuperAdmin() || (isSignedIn() && request.auth.uid == adminId);
      allow write: if isSuperAdmin();
    }

    // Invite Codes
    match /invite_codes/{codeId} {
      allow read: if true; // anyone can read to join
      allow create: if true; // anyone can create
      allow update: if true;
      allow delete: if true;
    }

    function isValidSharedFund(data) {
      return data.keys().hasAll(['ownerId', 'memberIds', 'members', 'funds'])
        && data.keys().size() >= 4
        && data.ownerId is string
        && data.memberIds is list && data.memberIds.size() > 0 && data.memberIds.size() <= 10
        && data.members is map
        && data.funds is list;
    }

    // Shared Funds
    match /shared_funds/{fundId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && request.auth.uid in resource.data.memberIds;
      allow create: if isSignedIn() && isValidId(fundId) && isValidSharedFund(incoming())
        && incoming().ownerId == request.auth.uid
        && request.auth.uid in incoming().memberIds;
      allow update: if isSignedIn() && isValidSharedFund(incoming())
        && incoming().ownerId == existing().ownerId
        && (request.auth.uid in existing().memberIds || 
            (request.auth.uid in incoming().memberIds && incoming().memberIds.hasAll(existing().memberIds)));
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;
    }
    
    // Couple Data
    match /couple_data/{dataId} {
      // In a real app we'd want to restrict read/write to the two users involved in the couple.
      // E.g. pairId = [uid1, uid2].sort() -> dataId starts with that pairId.
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(dataId);
    }

    function isValidPost(data) {
      return data.keys().hasAll(['authorId', 'createdAt']) // Allow flexible 'text', 'mediaUrls'
        && data.authorId == request.auth.uid;
    }

    // Posts Collection
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidPost(incoming());
      allow update: if isSignedIn() && existing().authorId == request.auth.uid;
      allow delete: if isSignedIn() && (existing().authorId == request.auth.uid || isAdmin());
      
      match /likes/{userId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
      
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && incoming().authorId == request.auth.uid;
        allow update, delete: if isSignedIn() && (existing().authorId == request.auth.uid || isAdmin());
      }
    }
  }
}
